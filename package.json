{
  "name": "pharmacy-management",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "build": "tsc && tsc-alias",
    "format": "pnpm lint --fix",
    "start": "node dist/src/index.js",
    "prisma:merge": "tsx scripts/merge-schema.ts",
    "prisma:generate": "npm run prisma:merge && prisma generate",
    "prisma:migrate": "npm run prisma:merge && prisma migrate dev",
    "prisma:deploy": "npm run prisma:merge && prisma migrate deploy"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.3",
    "@prisma/client": "^6.8.2",
    "@scalar/hono-api-reference": "^0.5.166",
    "axios": "^1.12.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.7.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^12.0.1",
    "hono": "^4.10.3",
    "hono-pino": "^0.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.11",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.14.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.14",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.18.0",
    "eslint-plugin-format": "^1.0.1",
    "prisma": "^6.8.2",
    "tsc-alias": "^1.8.11",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "@prisma/client"
    ]
  }
}
